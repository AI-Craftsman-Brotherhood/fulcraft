<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Temporarily suppress noisy warnings to avoid risky code changes. -->
    <Match>
        <Bug code="EI,EI2,RCN,Nm"/>
    </Match>
    <!-- Suppress Bad Practice warnings for constructor throws and unsafe getResource inheritance. -->
    <Match>
        <Bug code="CT"/>
    </Match>
    <Match>
        <Bug code="UI"/>
    </Match>
    <!-- 
        Suppress EI (Exposing Internal Representation) warnings for Config and related classes.
        These are configuration objects intentionally designed to be shared across components.
        Deep copying would be impractical and unnecessary for read-only configuration access.
        This includes both EI_EXPOSE_REP (getters) and EI_EXPOSE_REP2 (setters).
    -->
