    <!--
        Suppress common test-related warnings for all test classes.
        These patterns are common in JUnit test code and are not considered bugs:
        - UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR: Fields initialized in @BeforeEach
        - DM_DEFAULT_ENCODING: Encoding typically not critical in test code
        - NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE: Intentional null testing
        - RV_RETURN_VALUE_IGNORED: Fluent API assertions, mock returns
        - REC_CATCH_EXCEPTION: Broad exception catching for test utility code
        - DMI_HARDCODED_ABSOLUTE_FILENAME: Test fixture paths
        - DLS_DEAD_LOCAL_STORE: Unused test variables (often for future use)
        - ES_COMPARING_STRINGS_WITH_EQ: Intentional identity checks in tests
        - DP_DO_INSIDE_DO_PRIVILEGED: Tests don't need privileged blocks
        - CNT_ROUGH_CONSTANT_VALUE: Constant approximations in tests
    -->
    <Match>
        <Class name="~.*Test(\$.*)?$"/>
        <Or>
            <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
            <Bug pattern="DM_DEFAULT_ENCODING"/>
            <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
            <Bug pattern="RV_RETURN_VALUE_IGNORED"/>
            <Bug pattern="REC_CATCH_EXCEPTION"/>
            <Bug pattern="DMI_HARDCODED_ABSOLUTE_FILENAME"/>
            <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
            <Bug pattern="ES_COMPARING_STRINGS_WITH_EQ"/>
            <Bug pattern="DP_DO_INSIDE_DO_PRIVILEGED"/>
            <Bug pattern="CNT_ROUGH_CONSTANT_VALUE"/>
            <Bug pattern="DM_CONVERT_CASE"/>
            <Bug pattern="SIC_INNER_SHOULD_BE_STATIC_ANON"/>
            <Bug pattern="UC_USELESS_OBJECT"/>
        </Or>
    </Match>
