        <Class name="com.craftsmanbro.fulcraft.config.Config"/>
        <Bug code="EI,EI2"/>
    </Match>
    <Match>
        <Class name="~com\.example\.utgenerator\.application\.pipeline\.model\.Config\$.*"/>
        <Bug code="EI,EI2"/>
    </Match>
